{
  "name": "webmerge",
  "version": "1.0.0",
  "license": "MIT",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vp dev",
    "build": "vp run check && vp build",
    "build:chrome": "VITE_BROWSER_NAME=chrome vp run build",
    "build:firefox": "VITE_BROWSER_NAME=firefox vp run build",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "check:strict": "tsc --project tsconfig.strict.json --noEmit",
    "lint": "oxlint src/ --tsconfig=tsconfig.json",
    "lint:fix": "oxlint src/ --tsconfig=tsconfig.json --fix",
    "dead-code": "knip --config knip.config.ts",
    "analyze": "bun run check:strict && bun run lint && bun run dead-code",
    "fmt": "prettier --write src/",
    "clean": "rimraf dist .svelte-kit node_modules",
    "postbuild": "rimraf ./dist/.vite"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.4.0",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tailwindcss/postcss": "^4.2.2",
    "@tsconfig/svelte": "^5.0.8",
    "@types/chrome": "^0.1.38",
    "@types/node": "^25.5.0",
    "@types/turndown": "^5.0.6",
    "@types/uuid": "^11.0.0",
    "autoprefixer": "^10.4.27",
    "axios": "^1.13.6",
    "daisyui": "^5.5.19",
    "embla-carousel": "^8.6.0",
    "embla-carousel-autoplay": "^8.6.0",
    "embla-carousel-svelte": "^8.6.0",
    "knip": "^6.0.4",
    "lucide-svelte": "^0.577.0",
    "oxlint": "^1.57.0",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "prettier-plugin-svelte": "^3.5.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "rimraf": "^6.1.3",
    "svelte": "^5.54.1",
    "svelte-check": "^4.4.5",
    "svelte-sonner": "^1.1.0",
    "tailwindcss": "^4.2.2",
    "turndown": "^7.2.2",
    "typescript": "^5.9.3",
    "uuid": "^13.0.0",
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vite-plus": "^0.1.13",
    "zod": "^3.24.0"
  },
  "packageManager": "bun@1.3.6",
  "overrides": {
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
  }
}
