{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "exactOptionalPropertyTypes": false
  },
  "include": [
    "src/**/*.ts",
    "*.ts",
    "*.cjs",
    "*.js",
    "global.d.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "src/**/*.svelte"
  ]
}
